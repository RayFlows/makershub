page {
  background-color: #222831;
}

button:active {
  opacity: 0.8;
}

.container {
  min-height: 100vh;
  width: 100%;
  background-color: #222831;
  color: #FFFFFF;
  overflow-x: hidden;
}

.nav {
  height: 0;
}

.content {
  padding: 210rpx 64rpx 80rpx;
  box-sizing: border-box;
}

.status-box {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.status-title {
  font-size: 52rpx;
  font-weight: bold;
  line-height: 68rpx;
}

.status-desc {
  max-width: 620rpx;
  font-size: 28rpx;
  color: #D9D9D9;
  line-height: 42rpx;
  word-break: break-all;
}

.form-box,
.bound-box {
  width: 100%;
  padding: 44rpx 36rpx;
  background-color: #EEEEEE;
  border-radius: 24rpx;
  box-sizing: border-box;
  color: #222831;
}

.form-section {
  margin-bottom: 36rpx;
}

.label,
.bound-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #222831;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background-color: #FFFFFF;
  border: 3rpx solid #D9D9D9;
  border-radius: 18rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #222831;
}

.input.focused {
  border-color: #00ADB5;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
  min-width: 0;
}

.send-button {
  width: 168rpx;
  height: 88rpx;
  padding: 0;
  background-color: #00ADB5;
  color: #FFFFFF;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  font-weight: bold;
}

.submit-button,
.return-button {
  width: 100%;
  height: 96rpx;
  margin-top: 20rpx;
  padding: 0;
  background-color: #00ADB5;
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 32rpx;
  line-height: 96rpx;
  font-weight: bold;
}

.disabled {
  background-color: #9AA4A6;
}

.dev-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #00ADB5;
  line-height: 34rpx;
}

.bound-box {
  display: flex;
  flex-direction: column;
}

.bound-email {
  margin-bottom: 34rpx;
  font-size: 34rpx;
  font-weight: bold;
  line-height: 48rpx;
  word-break: break-all;
}
