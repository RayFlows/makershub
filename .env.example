# MakersHub 本地开发环境配置。
#
# 本地 Docker Compose 开发时复制为 .env 使用。
# 预发布和生产环境的密钥必须由部署平台注入，不能提交到仓库。

# 应用在健康检查和 OpenAPI 文档中展示的服务名称。
APP_NAME=MakersHub API

# 当前运行环境。local/test/development 允许开发态微信 dev_openid；production 会启用更严格校验。
APP_ENV=local

# 后端 V1 API 的统一前缀。
API_PREFIX=/api/v1

# 允许访问 API 的前端来源，多个来源用英文逗号分隔。
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# JWT 签名密钥。本地可用占位值，生产必须替换为至少 32 位强随机密钥。
JWT_SECRET_KEY=change-me-in-local-env-only-32-bytes

# JWT 签名算法，当前默认使用 HS256。
JWT_ALGORITHM=HS256

# access token 有效期，单位分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=120

# refresh token 有效期，单位天。
REFRESH_TOKEN_EXPIRE_DAYS=30

# 微信小程序 AppID，用于真实 wx.login code2session；本地纯 dev_openid 调试可留空。
# WECHAT_APP_ID=

# 微信小程序 AppSecret，用于真实 wx.login code2session；生产必须由密钥系统注入。
# WECHAT_APP_SECRET=

# 微信 code2session 接口地址，一般不需要修改，除非做测试替身服务。
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session

# 邮件发送模式。log 表示本地把验证码写入日志；smtp 表示通过真实邮箱发送。
EMAIL_DELIVERY_MODE=log

# 邮箱验证码有效期，单位分钟。
EMAIL_CODE_EXPIRE_MINUTES=5

# 同一邮箱两次发送验证码的最小间隔，单位秒。
EMAIL_CODE_RESEND_INTERVAL_SECONDS=60

# 同一邮箱每小时最多发送验证码次数。
EMAIL_CODE_HOURLY_LIMIT=10

# SMTP 服务器地址；启用 EMAIL_DELIVERY_MODE=smtp 时必须配置。
# 第一阶段验证码发信建议使用 Resend + scumaker.com：
# SMTP_HOST=smtp.resend.com

# SMTP 服务器端口，SSL 常用 465。Resend 支持 465/2465 的隐式 SSL，也支持 587/2587 的 STARTTLS。
# SMTP_PORT=465

# 是否使用 SSL 连接 SMTP 服务器。
# SMTP_USE_SSL=true

# SMTP 登录用户名。Resend SMTP 固定使用 resend。
# SMTP_USERNAME=resend

# SMTP 登录密码或授权码，不能提交真实生产值。Resend 这里填写 API Key。
# SMTP_PASSWORD=

# 邮件发件人地址。
# SMTP_FROM_EMAIL=auth@scumaker.com

# 邮件发件人展示名称。
# SMTP_FROM_NAME=MakersHub

# 邮件内点击品牌图片跳转的首页地址。
EMAIL_HOME_URL=https://scumaker.com

# 邮件品牌头图片地址。生产建议使用公开静态资源域名，指向 MinIO public bucket。
# EMAIL_BRAND_IMAGE_URL=https://static.scumaker.com/public/brand/SCUMAKER_logowithtext_email.png

# 后端数据库连接串。Docker Compose 内部主机名是 mysql；宿主机直连时通常改为 127.0.0.1。
DATABASE_URL=mysql+aiomysql://makershub:makershub@mysql:3306/makershub_dev

# Loguru 日志等级。
LOG_LEVEL=INFO

# 后端日志文件目录，容器内默认写到 apps/api/logs 或运行目录下的 logs。
LOG_DIR=logs

# 普通运行日志文件名。
LOG_APP_FILE=app.log

# 错误和严重错误日志文件名。
LOG_ERROR_FILE=error.log

# HTTP 请求日志文件名，记录方法、路径、状态码、耗时和 request_id。
LOG_REQUEST_FILE=request.log

# DEBUG 日志文件名，本地默认可启用，生产默认关闭。
LOG_DEBUG_FILE=debug.log

# 是否写入日志文件。
LOG_FILE_ENABLED=true

# 是否把日志输出到控制台。
LOG_CONSOLE_ENABLED=true

# 日志轮转时间或大小，00:00 表示每天零点轮转。
LOG_ROTATION=00:00

# 普通运行日志保留周期。
LOG_RETENTION=30 days

# 错误日志保留周期。
LOG_ERROR_RETENTION=180 days

# 请求日志保留周期。
LOG_REQUEST_RETENTION=30 days

# DEBUG 日志保留周期。
LOG_DEBUG_RETENTION=7 days

# 是否强制写 DEBUG 文件。留空表示非生产环境默认写，生产环境默认不写。
# LOG_DEBUG_FILE_ENABLED=true

# 日志轮转后的压缩格式。
LOG_COMPRESSION=zip

# 是否启用异步队列写日志，容器和多进程场景建议开启。
LOG_ENQUEUE=true

# 是否写入基础 HTTP 安全响应头。
SECURITY_HEADERS_ENABLED=true

# 是否启用 HSTS。留空时生产环境自动启用，本地自动关闭。
# HSTS_ENABLED=

# HSTS 过期时间，单位秒。
HSTS_MAX_AGE_SECONDS=63072000

# 是否启用非上传接口请求体大小限制。
REQUEST_SIZE_LIMIT_ENABLED=true

# 普通请求体最大字节数，默认 2 MiB。
MAX_REQUEST_BODY_BYTES=2097152

# 是否启用应用层限流。
RATE_LIMIT_ENABLED=true

# 普通接口限流窗口，单位秒。
RATE_LIMIT_WINDOW_SECONDS=60

# 普通接口每个限流窗口内最大请求数。
RATE_LIMIT_MAX_REQUESTS=300

# 认证敏感接口限流窗口，单位秒。
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# 认证敏感接口每个限流窗口内最大请求数。
AUTH_RATE_LIMIT_MAX_REQUESTS=30

# 不参与限流的路径，多个路径用英文逗号分隔。
RATE_LIMIT_EXEMPT_PATHS=/health,/api/v1/health,/api/v1/docs,/api/v1/openapi.json

# 使用更严格认证限流的路径，多个路径用英文逗号分隔。
AUTH_RATE_LIMIT_PATHS=/api/v1/auth/wechat/login,/api/v1/auth/password/login,/api/v1/auth/email/send-code,/api/v1/auth/email/first-login,/api/v1/auth/refresh

# MySQL root 用户密码，仅用于本地 Docker Compose。
MYSQL_ROOT_PASSWORD=makershub_root

# MySQL 默认创建的业务数据库名。
MYSQL_DATABASE=makershub_dev

# MySQL 默认创建的业务用户名。
MYSQL_USER=makershub

# MySQL 业务用户密码。
MYSQL_PASSWORD=makershub

# 后端访问 MinIO 的内部地址。Docker Compose 内部主机名是 minio。
MINIO_ENDPOINT=minio:9000

# MinIO 访问账号，本地开发默认 makershub。
MINIO_ACCESS_KEY=makershub

# MinIO 访问密钥，本地开发默认占位值，生产必须替换。
MINIO_SECRET_KEY=makershub_minio

# MinIO 默认业务桶名，保留给通用文件用途。
MINIO_BUCKET_NAME=makershub-local

# MinIO 对外访问地址，前端或调试工具访问对象存储时使用。
MINIO_PUBLIC_URL=http://localhost:9000

# MinIO 控制台浏览器跳转地址。
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# 用户头像文件桶名。
MINIO_AVATAR_BUCKET=makershub-avatars-local

# 可公开读取的公共资源桶名。
MINIO_PUBLIC_BUCKET=makershub-public-local

# 资源和物资相关文件桶名。
MINIO_RESOURCE_BUCKET=makershub-resources-local

# 项目材料和归档文件桶名。
MINIO_PROJECT_BUCKET=makershub-projects-local

# 临时上传或待处理文件桶名。
MINIO_TEMP_BUCKET=makershub-temp-local

# 初始化唯一 999 母账号时使用的初始密码；不要提交真实生产值。
# INITIAL_SUPER_ADMIN_PASSWORD=

# 前端调用后端 API 的基础地址。
VITE_API_BASE_URL=http://localhost:8000/api/v1
