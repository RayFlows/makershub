# MakersHub local development environment.
#
# Copy this file to .env for Docker Compose development. Production and staging
# secrets must be provided by the deployment platform and must not be committed.

APP_NAME=MakersHub API
APP_ENV=local
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# JWT and authentication.
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# WeChat mini program login. Local development can use dev_openid in the API.
# Production must provide real values.
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session

# Email verification. Local development logs verification codes.
EMAIL_DELIVERY_MODE=log
EMAIL_CODE_EXPIRE_MINUTES=5
EMAIL_CODE_RESEND_INTERVAL_SECONDS=60
EMAIL_CODE_HOURLY_LIMIT=10
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USERNAME=auth@makershub.cn
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=auth@makershub.cn
# SMTP_FROM_NAME=MakersHub

# MySQL inside Docker Compose.
DATABASE_URL=mysql+aiomysql://makershub:makershub@mysql:3306/makershub_dev

# Logging. Request logs include X-Request-ID but do not record request bodies.
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_APP_FILE=app.log
LOG_ERROR_FILE=error.log
LOG_REQUEST_FILE=request.log
LOG_DEBUG_FILE=debug.log
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_ROTATION=00:00
LOG_RETENTION=30 days
LOG_ERROR_RETENTION=180 days
LOG_REQUEST_RETENTION=30 days
LOG_DEBUG_RETENTION=7 days
# Leave unset to enable debug files outside production and disable them in production.
# LOG_DEBUG_FILE_ENABLED=true
LOG_COMPRESSION=zip
LOG_ENQUEUE=true

MYSQL_ROOT_PASSWORD=makershub_root
MYSQL_DATABASE=makershub_dev
MYSQL_USER=makershub
MYSQL_PASSWORD=makershub

# MinIO inside Docker Compose.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=makershub
MINIO_SECRET_KEY=makershub_minio
MINIO_BUCKET_NAME=makershub-local
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

MINIO_AVATAR_BUCKET=makershub-avatars-local
MINIO_PUBLIC_BUCKET=makershub-public-local
MINIO_RESOURCE_BUCKET=makershub-resources-local
MINIO_PROJECT_BUCKET=makershub-projects-local
MINIO_TEMP_BUCKET=makershub-temp-local

# Initial 999 bootstrap. Do not commit real production values.
# INITIAL_SUPER_ADMIN_PASSWORD=

# Frontend runtime defaults.
VITE_API_BASE_URL=http://localhost:8000/api/v1
